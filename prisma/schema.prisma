generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            String        @id @default(cuid())
  name          String
  sourceType    String
  defaultPeriod String        @default("day")
  timezone      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  repoSource    RepoSource?
  branchRule    BranchRule?
  authorRule    AuthorRule?
  llmProfile    LlmProfile?
  syncRuns      SyncRun[]
  commits       CommitRecord[]
  reports       ReportRun[]
}

model RepoSource {
  id        String   @id @default(cuid())
  projectId String   @unique
  localPath String?
  remoteUrl String?
  cacheDir  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BranchRule {
  id                   String   @id @default(cuid())
  projectId            String   @unique
  mode                 String   @default("all")
  selectedBranchesJson String   @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuthorRule {
  id         String   @id @default(cuid())
  projectId  String   @unique
  namesJson  String   @default("[]")
  emailsJson String   @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LlmProfile {
  id          String   @id @default(cuid())
  projectId   String   @unique
  baseUrl     String?
  apiKey      String?
  model       String?
  temperature Float    @default(0.3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SyncRun {
  id                 String        @id @default(cuid())
  projectId          String
  status             String
  message            String?
  scannedRepoPath    String?
  branchSnapshotJson String        @default("[]")
  commitCount        Int           @default(0)
  startedAt          DateTime      @default(now())
  finishedAt         DateTime?
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commits            CommitRecord[]

  @@index([projectId, startedAt])
}

model CommitRecord {
  id           String    @id @default(cuid())
  projectId    String
  syncRunId    String?
  hash         String
  authorName   String
  authorEmail  String
  committedAt  DateTime
  subject      String
  body         String?
  refNamesJson String    @default("[]")
  filesJson    String    @default("[]")
  additions    Int       @default(0)
  deletions    Int       @default(0)
  createdAt    DateTime  @default(now())
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  syncRun      SyncRun?  @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@unique([projectId, hash])
  @@index([projectId, committedAt])
}

model ReportRun {
  id              String   @id @default(cuid())
  projectId       String
  period          String
  rangeStart      DateTime
  rangeEnd        DateTime
  timezone        String
  branchNamesJson String   @default("[]")
  authorNamesJson String   @default("[]")
  authorEmailsJson String  @default("[]")
  commitHashesJson String  @default("[]")
  totalCommits    Int      @default(0)
  markdown        String
  structuredJson  String   @default("{}")
  llmProvider     String?
  llmModel        String?
  status          String   @default("success")
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
