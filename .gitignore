# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling and caches
/.tools/
/bootstrap-app/
/.cache/
/.downloads/
/.tmp/
/playwright-report/
/test-results/
/coverage/
/tmp/

# database
/prisma/dev.db
/prisma/dev.db-journal

# runtime exports
/reports/

# 本地运行数据目录（数据库、缓存、运行时日志）
/data/

# 环境变量（.env.example 保留，.env 不入库）
.env
