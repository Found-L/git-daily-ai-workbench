# Git 日报 AI 工作台 —— 环境变量模板
# 复制此文件为 .env，按需填写，未填写的项目使用默认值。

# ─────────────────────────────────────────────────────────────
# 服务端口（本地运行与 Docker 均适用）
# 默认 3000
# ─────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────
# 数据目录（Docker 部署建议挂载到宿主机固定目录）
# 本地运行时默认为项目根目录下的 data/
# ─────────────────────────────────────────────────────────────
# APP_DATA_DIR=./data

# ─────────────────────────────────────────────────────────────
# 数据库路径（Prisma SQLite 格式）
# Docker 部署时由 compose.yaml 自动设置，一般无需手动修改
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=file:./data/db/workbench.db

# ─────────────────────────────────────────────────────────────
# 仓库缓存根目录（远程仓库克隆到本地的目录）
# ─────────────────────────────────────────────────────────────
# APP_CACHE_ROOT=./data/cache

# ─────────────────────────────────────────────────────────────
# Git 可执行文件路径（留空时自动探测系统 Git）
# ─────────────────────────────────────────────────────────────
# GIT_BINARY=

# ─────────────────────────────────────────────────────────────
# 绑定地址（默认仅本机可访问）
# Docker 部署时通常不需要修改，由 compose ports 控制
# ─────────────────────────────────────────────────────────────
# HOST=127.0.0.1
